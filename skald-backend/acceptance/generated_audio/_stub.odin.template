Skald_Param_Info :: struct {
	name:    string,
	min:     f32,
	max:     f32,
	default: f32,
	unit:    string,
}

Asset_Processor :: struct {
	sample_rate:  f32,
	playing:      bool,
	voice_active: bool,
}

Asset_PARAMS := []Skald_Param_Info{}

Asset_init :: proc(p: ^Asset_Processor, sr: f32) {
	p.sample_rate = sr
}

Asset_trigger :: proc(p: ^Asset_Processor, note: u8 = 60, velocity: f32 = 1.0, duration: f32 = 0.0) {
	p.voice_active = true
}

Asset_start :: proc(p: ^Asset_Processor) {
	p.playing = true
}

Asset_process :: proc(p: ^Asset_Processor) -> (f32, f32) {
	return 0, 0
}

Asset_set_param :: proc(p: ^Asset_Processor, name: string, value: f32) -> bool {
	return false
}

Asset_get_param :: proc(p: ^Asset_Processor, name: string) -> (f32, bool) {
	return 0.0, false
}
