Asset_set_param :: proc(p: ^Asset_Processor, name: string, value: f32) -> bool {
	switch name {
	case "Osc_A_amplitude":
		Asset_set_Osc_A_amplitude(p, value)
		return true
	case "Osc_A_frequency":
		Asset_set_Osc_A_frequency(p, value)
		return true
	case "Osc_A_phase":
		Asset_set_Osc_A_phase(p, value)
		return true
	case "Osc_A_pulseWidth":
		Asset_set_Osc_A_pulseWidth(p, value)
		return true
	case "Osc_B_amplitude":
		Asset_set_Osc_B_amplitude(p, value)
		return true
	case "Osc_B_frequency":
		Asset_set_Osc_B_frequency(p, value)
		return true
	case "Osc_B_phase":
		Asset_set_Osc_B_phase(p, value)
		return true
	case "Osc_B_pulseWidth":
		Asset_set_Osc_B_pulseWidth(p, value)
		return true
	case "attack":
		Asset_set_attack(p, value)
		return true
	case "decay":
		Asset_set_decay(p, value)
		return true
	case "depth":
		Asset_set_depth(p, value)
		return true
	case "release":
		Asset_set_release(p, value)
		return true
	case "sustain":
		Asset_set_sustain(p, value)
		return true
	}
	return false
}

Asset_get_param :: proc(p: ^Asset_Processor, name: string) -> (f32, bool) {
	switch name {
	case "Osc_A_amplitude":
		return p.Osc_A_amplitude, true
	case "Osc_A_frequency":
		return p.Osc_A_frequency, true
	case "Osc_A_phase":
		return p.Osc_A_phase, true
	case "Osc_A_pulseWidth":
		return p.Osc_A_pulseWidth, true
	case "Osc_B_amplitude":
		return p.Osc_B_amplitude, true
	case "Osc_B_frequency":
		return p.Osc_B_frequency, true
	case "Osc_B_phase":
		return p.Osc_B_phase, true
	case "Osc_B_pulseWidth":
		return p.Osc_B_pulseWidth, true
	case "attack":
		return p.attack, true
	case "decay":
		return p.decay, true
	case "depth":
		return p.depth, true
	case "release":
		return p.release, true
	case "sustain":
		return p.sustain, true
	}
	return 0.0, false
}

Asset_process :: proc(p: ^Asset_Processor) -> (f32, f32) {
	sample_rate := p.sample_rate
	output_left: f32 = 0.0
	output_right: f32 = 0.0
	p.total_samples += 1

	for v_idx in 0..<8 {
		voice := &p.voices[v_idx]
		if !voice.active do continue

		voice.age += 1.0 / sample_rate;
		if voice.current_freq != voice.target_freq {
			glide_k := 1.0 / math.max(voice.glide_time * sample_rate, 1.0)
			if glide_k > 1.0 do glide_k = 1.0
			voice.current_freq += (voice.target_freq - voice.current_freq) * glide_k
			if abs(voice.target_freq - voice.current_freq) < 0.1 do voice.current_freq = voice.target_freq
		}
		if voice.age >= voice.duration && voice.duration > 0.0 {
			if voice.adsr_4_stage != .Release && voice.adsr_4_stage != .Idle {
				voice.adsr_4_stage = .Release
				voice.time_released = voice.age
			}
		}
		voice_busy := false
		node_1_out: f32 = 0.0
		node_2_out: f32 = 0.0
		node_3_out: f32 = 0.0
		node_4_out: f32 = 0.0
		node_5_out: f32 = 0.0

		// --- Oscillator Node 1 (Unison/Detune) ---
		{
			unison_out: f32 = 0.0;
			unison_count := 1;
			for i in 0..<unison_count {
				detune_amount: f32 = 0.0;
				if unison_count > 1 do detune_amount = (f32(i) / (f32(unison_count) - 1.0) - 0.5) * 2.0 * (5.000000000);
				detuned_freq: f32 = (voice.current_freq) * math.pow(2.0, detune_amount / 1200.0);
				phase_rads: f32 = f32(p.Osc_A_phase) * (f32(math.PI) / 180.0);
				voice.osc_1_phase[i] = math.mod(voice.osc_1_phase[i] + (2 * f32(math.PI) * detuned_freq / sample_rate), 2 * f32(math.PI));
				final_phase := math.mod(voice.osc_1_phase[i] + phase_rads, 2 * f32(math.PI));
				unison_out += math.sin(final_phase);
			}
			if unison_count > 0 do node_1_out = (unison_out / f32(unison_count)) * (p.Osc_A_amplitude);
		}

		// --- Oscillator Node 2 (Unison/Detune) ---
		{
			unison_out: f32 = 0.0;
			unison_count := 1;
			for i in 0..<unison_count {
				detune_amount: f32 = 0.0;
				if unison_count > 1 do detune_amount = (f32(i) / (f32(unison_count) - 1.0) - 0.5) * 2.0 * (5.000000000);
				detuned_freq: f32 = (voice.current_freq) * math.pow(2.0, detune_amount / 1200.0);
				phase_rads: f32 = f32(p.Osc_B_phase) * (f32(math.PI) / 180.0);
				voice.osc_2_phase[i] = math.mod(voice.osc_2_phase[i] + (2 * f32(math.PI) * detuned_freq / sample_rate), 2 * f32(math.PI));
				final_phase := math.mod(voice.osc_2_phase[i] + phase_rads, 2 * f32(math.PI));
				unison_out += math.sin(final_phase);
			}
			if unison_count > 0 do node_2_out = (unison_out / f32(unison_count)) * (p.Osc_B_amplitude);
		}

		// --- Mixer Node 3 (2 inputs) ---
		{
			mix_sum_3: f32 = 0.0;
			mix_sum_3 += node_1_out * (f32(1.000000000));
			mix_sum_3 += node_2_out * (f32(1.000000000));
		node_3_out = mix_sum_3;
		}

		// --- ADSR Node 4 ---
		{
			envelope: f32 = 0.0;
			switch voice.adsr_4_stage {
			case .Idle:
				envelope = 0.0;
			case .Attack:
				if (p.attack) > 0 do envelope = voice.age / math.max(f32(p.attack), 0.000001); else do envelope = 1.0;
				voice.adsr_4_release_level = envelope;
				if voice.age >= (p.attack) {
					voice.adsr_4_stage = .Decay;
				}
			case .Decay:
				time_in_decay := voice.age - (p.attack);
				if (p.decay) > 0 do envelope = 1.0 - (time_in_decay / math.max(f32(p.decay), 0.000001)) * (1.0 - (p.sustain)); else do envelope = (p.sustain);
				voice.adsr_4_release_level = envelope;
				if time_in_decay >= (p.decay) {
					voice.adsr_4_stage = .Sustain;
				}
			case .Sustain:
				envelope = (p.sustain);
				voice.adsr_4_release_level = envelope;
				if envelope <= 0.0001 do voice.adsr_4_stage = .Idle;
			case .Release:
				time_in_release := voice.age - voice.time_released;
				if (p.release) > 0 do envelope = voice.adsr_4_release_level * (1.0 - (time_in_release / math.max(f32(p.release), 0.000001))); else do envelope = 0.0;
				if envelope <= 0 {
					envelope = 0;
					voice.adsr_4_stage = .Idle;
				}
			}
			vel_scale_4: f32 = (1.0 - (f32(0.500000000))) + (f32(0.500000000)) * voice.velocity;
			node_4_out = ((node_3_out)) * envelope * (p.depth) * vel_scale_4;
		}

		output_left += node_4_out
		output_right += node_4_out
		if voice.adsr_4_stage != .Idle do voice_busy = true
		if !voice_busy do voice.active = false
	}
	return output_left, output_right
}
Asset_process_sequence :: proc(p: ^Asset_Processor) {
}

// --- Project Wrapper (test-harness convenience) ---
Project_State :: struct {
	Asset: ^Asset_Processor,
}

project_init :: proc(p: ^Project_State, sr: f32) {
	p.Asset = new(Asset_Processor)
	Asset_init(p.Asset, sr)
}

project_process :: proc(p: ^Project_State) -> (f32, f32) {
	mixed_left: f32 = 0.0
	mixed_right: f32 = 0.0
	{ l, r := Asset_process(p.Asset); mixed_left += l; mixed_right += r }
	mixed_left = math.tanh(mixed_left * 0.800000012)
	mixed_right = math.tanh(mixed_right * 0.800000012)
	return mixed_left, mixed_right
}

project_destroy :: proc(p: ^Project_State) {
	free(p.Asset)
}

