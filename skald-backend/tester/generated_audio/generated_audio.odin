	if v < 0.100 do v = 0.100
	if v > 20.000 do v = 20.000
	p.resonance = v
}

Bass_2_set_phase :: proc(p: ^Bass_2_Processor, value: f32) {
	v := value
	if v < 0.000 do v = 0.000
	if v > 360.000 do v = 360.000
	p.phase = v
}

Bass_2_set_depth :: proc(p: ^Bass_2_Processor, value: f32) {
	v := value
	if v < 0.000 do v = 0.000
	if v > 1.000 do v = 1.000
	p.depth = v
}

Bass_2_set_amplitude :: proc(p: ^Bass_2_Processor, value: f32) {
	v := value
	if v < 0.000 do v = 0.000
	if v > 1.000 do v = 1.000
	p.amplitude = v
}

Bass_2_PARAMS := []Skald_Param_Info{
	{"pulseWidth", 0.000, 1.000, 0.500, ""},
	{"release", 0.001, 10.000, 1.000, "s"},
	{"sustain", 0.000, 1.000, 0.500, ""},
	{"decay", 0.001, 10.000, 0.200, "s"},
	{"frequency", 20.000, 20000.000, 26.917, "Hz"},
	{"cutoff", 20.000, 20000.000, 800.000, "Hz"},
	{"attack", 0.001, 10.000, 0.100, "s"},
	{"resonance", 0.100, 20.000, 1.000, "Q"},
	{"phase", 0.000, 360.000, 0.000, "deg"},
	{"depth", 0.000, 1.000, 1.000, ""},
	{"amplitude", 0.000, 1.000, 0.500, ""},
}

Bass_2_set_param :: proc(p: ^Bass_2_Processor, name: string, value: f32) -> bool {
	switch name {
	case "pulseWidth":
		Bass_2_set_pulseWidth(p, value)
		return true
	case "release":
		Bass_2_set_release(p, value)
		return true
	case "sustain":
		Bass_2_set_sustain(p, value)
		return true
	case "decay":
		Bass_2_set_decay(p, value)
		return true
	case "frequency":
		Bass_2_set_frequency(p, value)
		return true
	case "cutoff":
		Bass_2_set_cutoff(p, value)
		return true
	case "attack":
		Bass_2_set_attack(p, value)
		return true
	case "resonance":
		Bass_2_set_resonance(p, value)
		return true
	case "phase":
		Bass_2_set_phase(p, value)
		return true
	case "depth":
		Bass_2_set_depth(p, value)
		return true
	case "amplitude":
		Bass_2_set_amplitude(p, value)
		return true
	}
	return false
}

Bass_2_get_param :: proc(p: ^Bass_2_Processor, name: string) -> (f32, bool) {
	switch name {
	case "pulseWidth":
		return p.pulseWidth, true
	case "release":
		return p.release, true
	case "sustain":
		return p.sustain, true
	case "decay":
		return p.decay, true
	case "frequency":
		return p.frequency, true
	case "cutoff":
		return p.cutoff, true
	case "attack":
		return p.attack, true
	case "resonance":
		return p.resonance, true
	case "phase":
		return p.phase, true
	case "depth":
		return p.depth, true
	case "amplitude":
		return p.amplitude, true
	}
	return 0.0, false
}

Bass_2_process :: proc(p: ^Bass_2_Processor) -> (f32, f32) {
	sample_rate := p.sample_rate
	output_left: f32 = 0.0
	output_right: f32 = 0.0
	Bass_2_process_sequence(p)
	p.total_samples += 1

	for v_idx in 0..<8 {
		voice := &p.voices[v_idx]
		if !voice.active do continue

		voice.age += 1.0 / sample_rate;
		if voice.current_freq != voice.target_freq {
			glide_k := 1.0 / math.max(voice.glide_time * sample_rate, 1.0)
			if glide_k > 1.0 do glide_k = 1.0
			voice.current_freq += (voice.target_freq - voice.current_freq) * glide_k
			if abs(voice.target_freq - voice.current_freq) < 0.1 do voice.current_freq = voice.target_freq
		}
		if voice.age >= voice.duration && voice.duration > 0.0 {
			if voice.adsr_3_stage != .Release && voice.adsr_3_stage != .Idle {
				voice.adsr_3_stage = .Release
				voice.time_released = voice.age
			}
		}
		voice_busy := false
		node_2_out: f32 = 0.0
		node_1_out: f32 = 0.0
		node_4_out: f32 = 0.0
		node_3_out: f32 = 0.0

		// --- Oscillator Node 1 (Unison/Detune) ---
		{
			unison_out: f32 = 0.0;
			unison_count := 1;
			for i in 0..<unison_count {
				detune_amount: f32 = 0.0;
				if unison_count > 1 do detune_amount = (f32(i) / (f32(unison_count) - 1.0) - 0.5) * 2.0 * (5.000);
				detuned_freq := (voice.current_freq) * math.pow(2.0, detune_amount / 1200.0);
				phase_rads := f32(p.phase) * (f32(math.PI) / 180.0);
				voice.osc_1_phase[i] = math.mod(voice.osc_1_phase[i] + (2 * f32(math.PI) * detuned_freq / sample_rate), 2 * f32(math.PI));
				final_phase := math.mod(voice.osc_1_phase[i] + phase_rads, 2 * f32(math.PI));
				unison_out += ((final_phase / f32(math.PI)) - 1.0);
			}
			if unison_count > 0 do node_1_out = (unison_out / f32(unison_count)) * (p.amplitude);
		}

		// --- Filter Node 2 (SVF) ---
		{
			cutoff_c_2 := math.clamp(f32(p.cutoff), 10.0, sample_rate * 0.16);
			f_2 := f32(2.0 * math.sin(f32(math.PI) * cutoff_c_2 / sample_rate));
			q_2 := math.clamp(1.0 / math.max(f32(p.resonance), 0.1), 0.05, 1.9 - f_2);
			voice.filter_2_low += f_2 * voice.filter_2_band;
			high_2 := f32(((node_1_out)) - voice.filter_2_low - q_2 * voice.filter_2_band);
			voice.filter_2_band += f_2 * high_2;
			node_2_out = voice.filter_2_low;
		}

		// --- ADSR Node 3 ---
		{
			envelope: f32 = 0.0;
			switch voice.adsr_3_stage {
			case .Idle:
				envelope = 0.0;
			case .Attack:
				if (p.attack) > 0 do envelope = voice.age / math.max(f32(p.attack), 0.000001); else do envelope = 1.0;
				voice.adsr_3_release_level = envelope;
				if voice.age >= (p.attack) {
					voice.adsr_3_stage = .Decay;
				}
			case .Decay:
				time_in_decay := voice.age - (p.attack);
				if (p.decay) > 0 do envelope = 1.0 - (time_in_decay / math.max(f32(p.decay), 0.000001)) * (1.0 - (p.sustain)); else do envelope = (p.sustain);
				voice.adsr_3_release_level = envelope;
				if time_in_decay >= (p.decay) {
					voice.adsr_3_stage = .Sustain;
				}
			case .Sustain:
				envelope = (p.sustain);
				voice.adsr_3_release_level = envelope;
				if envelope <= 0.0001 do voice.adsr_3_stage = .Idle;
			case .Release:
				time_in_release := voice.age - voice.time_released;
				if (p.release) > 0 do envelope = voice.adsr_3_release_level * (1.0 - (time_in_release / math.max(f32(p.release), 0.000001))); else do envelope = 0.0;
				if envelope <= 0 {
					envelope = 0;
					voice.adsr_3_stage = .Idle;
				}
			}
			vel_scale_3 := (1.0 - (0.500)) + (0.500) * voice.velocity;
			node_3_out = ((node_2_out)) * envelope * (p.depth) * vel_scale_3;
		}

		output_left += node_3_out
		output_right += node_3_out
		if voice.adsr_3_stage != .Idle do voice_busy = true
		if !voice_busy do voice.active = false
	}
	return output_left, output_right
}
Bass_2_process_sequence :: proc(p: ^Bass_2_Processor) {
	if !p.playing do return
	samples_per_step_f := p.sample_rate * 60.0 / (p.bpm * 4.0)
	if p.samples_until_next_step == 0 {
		switch p.current_step % 16 {
		case 0:
			Bass_2_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 5:
			Bass_2_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 9:
			Bass_2_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 13:
			Bass_2_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		}
		p.current_step += 1
		if p.current_step >= 16 {
			if p.loop {
				p.current_step = 0
			} else {
				p.playing = false
			}
		}
		p.step_frac_acc += samples_per_step_f
		n_step := u64(math.max(p.step_frac_acc, 1.0))
		p.step_frac_acc -= f32(n_step)
		p.samples_until_next_step = n_step - 1
	} else {
		p.samples_until_next_step -= 1
	}
}

// --- Project Wrapper (test-harness convenience) ---
Project_State :: struct {
	Bass: ^Bass_Processor,
	Bass_2: ^Bass_2_Processor,
}

project_init :: proc(p: ^Project_State, sr: f32) {
	p.Bass = new(Bass_Processor)
	Bass_init(p.Bass, sr)
	Bass_start(p.Bass)
	p.Bass_2 = new(Bass_2_Processor)
	Bass_2_init(p.Bass_2, sr)
	Bass_2_start(p.Bass_2)
}

project_process :: proc(p: ^Project_State) -> (f32, f32) {
	mixed_left: f32 = 0.0
	mixed_right: f32 = 0.0
	{ l, r := Bass_process(p.Bass); mixed_left += l; mixed_right += r }
	{ l, r := Bass_2_process(p.Bass_2); mixed_left += l; mixed_right += r }
	mixed_left = math.tanh(mixed_left * 0.800)
	mixed_right = math.tanh(mixed_right * 0.800)
	return mixed_left, mixed_right
}

project_destroy :: proc(p: ^Project_State) {
	free(p.Bass)
	free(p.Bass_2)
}

