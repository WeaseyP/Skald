}

Tuba_set_param :: proc(p: ^Tuba_Processor, name: string, value: f32) -> bool {
	switch name {
	case "ADSR_attack":
		Tuba_set_ADSR_attack(p, value)
		return true
	case "ADSR_attack_2":
		Tuba_set_ADSR_attack_2(p, value)
		return true
	case "ADSR_decay":
		Tuba_set_ADSR_decay(p, value)
		return true
	case "ADSR_decay_2":
		Tuba_set_ADSR_decay_2(p, value)
		return true
	case "ADSR_depth":
		Tuba_set_ADSR_depth(p, value)
		return true
	case "ADSR_depth_2":
		Tuba_set_ADSR_depth_2(p, value)
		return true
	case "ADSR_release":
		Tuba_set_ADSR_release(p, value)
		return true
	case "ADSR_release_2":
		Tuba_set_ADSR_release_2(p, value)
		return true
	case "ADSR_sustain":
		Tuba_set_ADSR_sustain(p, value)
		return true
	case "ADSR_sustain_2":
		Tuba_set_ADSR_sustain_2(p, value)
		return true
	case "LFO_amplitude":
		Tuba_set_LFO_amplitude(p, value)
		return true
	case "LFO_frequency":
		Tuba_set_LFO_frequency(p, value)
		return true
	case "Oscillator_amplitude":
		Tuba_set_Oscillator_amplitude(p, value)
		return true
	case "Oscillator_frequency":
		Tuba_set_Oscillator_frequency(p, value)
		return true
	case "cutoff":
		Tuba_set_cutoff(p, value)
		return true
	case "phase":
		Tuba_set_phase(p, value)
		return true
	case "pulseWidth":
		Tuba_set_pulseWidth(p, value)
		return true
	case "resonance":
		Tuba_set_resonance(p, value)
		return true
	}
	return false
}

Tuba_get_param :: proc(p: ^Tuba_Processor, name: string) -> (f32, bool) {
	switch name {
	case "ADSR_attack":
		return p.ADSR_attack, true
	case "ADSR_attack_2":
		return p.ADSR_attack_2, true
	case "ADSR_decay":
		return p.ADSR_decay, true
	case "ADSR_decay_2":
		return p.ADSR_decay_2, true
	case "ADSR_depth":
		return p.ADSR_depth, true
	case "ADSR_depth_2":
		return p.ADSR_depth_2, true
	case "ADSR_release":
		return p.ADSR_release, true
	case "ADSR_release_2":
		return p.ADSR_release_2, true
	case "ADSR_sustain":
		return p.ADSR_sustain, true
	case "ADSR_sustain_2":
		return p.ADSR_sustain_2, true
	case "LFO_amplitude":
		return p.LFO_amplitude, true
	case "LFO_frequency":
		return p.LFO_frequency, true
	case "Oscillator_amplitude":
		return p.Oscillator_amplitude, true
	case "Oscillator_frequency":
		return p.Oscillator_frequency, true
	case "cutoff":
		return p.cutoff, true
	case "phase":
		return p.phase, true
	case "pulseWidth":
		return p.pulseWidth, true
	case "resonance":
		return p.resonance, true
	}
	return 0.0, false
}

Tuba_process :: proc(p: ^Tuba_Processor) -> (f32, f32) {
	sample_rate := p.sample_rate
	output_left: f32 = 0.0
	output_right: f32 = 0.0
	Tuba_process_sequence(p)
	p.total_samples += 1

	for v_idx in 0..<8 {
		voice := &p.voices[v_idx]
		if !voice.active do continue

		voice.age += 1.0 / sample_rate;
		if voice.current_freq != voice.target_freq {
			glide_k := 1.0 / math.max(voice.glide_time * sample_rate, 1.0)
			if glide_k > 1.0 do glide_k = 1.0
			voice.current_freq += (voice.target_freq - voice.current_freq) * glide_k
			if abs(voice.target_freq - voice.current_freq) < 0.1 do voice.current_freq = voice.target_freq
		}
		if voice.age >= voice.duration && voice.duration > 0.0 {
			if voice.adsr_3_stage != .Release && voice.adsr_3_stage != .Idle {
				voice.adsr_3_stage = .Release
				voice.time_released = voice.age
			}
			if voice.adsr_4_stage != .Release && voice.adsr_4_stage != .Idle {
				voice.adsr_4_stage = .Release
				voice.time_released = voice.age
			}
		}
		voice_busy := false
		node_1_out: f32 = 0.0
		node_2_out: f32 = 0.0
		node_3_out: f32 = 0.0
		node_4_out: f32 = 0.0
		node_5_out: f32 = 0.0
		node_6_out: f32 = 0.0
		node_7_out: f32 = 0.0

		// --- ADSR Node 4 ---
		{
			envelope: f32 = 0.0;
			switch voice.adsr_4_stage {
			case .Idle:
				envelope = 0.0;
			case .Attack:
				if (p.ADSR_attack_2) > 0 do envelope = voice.age / math.max(f32(p.ADSR_attack_2), 0.000001); else do envelope = 1.0;
				voice.adsr_4_release_level = envelope;
				if voice.age >= (p.ADSR_attack_2) {
					voice.adsr_4_stage = .Decay;
				}
			case .Decay:
				time_in_decay := voice.age - (p.ADSR_attack_2);
				if (p.ADSR_decay_2) > 0 do envelope = 1.0 - (time_in_decay / math.max(f32(p.ADSR_decay_2), 0.000001)) * (1.0 - (p.ADSR_sustain_2)); else do envelope = (p.ADSR_sustain_2);
				voice.adsr_4_release_level = envelope;
				if time_in_decay >= (p.ADSR_decay_2) {
					voice.adsr_4_stage = .Sustain;
				}
			case .Sustain:
				envelope = (p.ADSR_sustain_2);
				voice.adsr_4_release_level = envelope;
				if envelope <= 0.0001 do voice.adsr_4_stage = .Idle;
			case .Release:
				time_in_release := voice.age - voice.time_released;
				if (p.ADSR_release_2) > 0 do envelope = voice.adsr_4_release_level * (1.0 - (time_in_release / math.max(f32(p.ADSR_release_2), 0.000001))); else do envelope = 0.0;
				if envelope <= 0 {
					envelope = 0;
					voice.adsr_4_stage = .Idle;
				}
			}
			vel_scale_4: f32 = (1.0 - (f32(0.500000000))) + (f32(0.500000000)) * voice.velocity;
			node_4_out = (1.0) * envelope * (p.ADSR_depth_2) * vel_scale_4;
		}

		// --- LFO Node 6 ---
		voice.lfo_6_phase = math.mod(voice.lfo_6_phase + (2 * f32(math.PI) * (p.LFO_frequency) / sample_rate), 2 * f32(math.PI));
		if voice.lfo_6_phase < 0.0 do voice.lfo_6_phase += 2 * f32(math.PI);
		node_6_out = math.sin(voice.lfo_6_phase) * (p.LFO_amplitude);

		// --- Mapper Node 5 ---
		{
			in_range_5: f32 = f32(f32(1.000000000)) - f32(f32(0.000000000));
			if in_range_5 == 0.0 do in_range_5 = 1.0;
			node_5_out = math.lerp(f32(f32(0.000000000)), f32(f32(700.000000000)), math.clamp((f32((node_4_out)) - f32(f32(0.000000000))) / in_range_5, 0.0, 1.0));
		}

		// --- Oscillator Node 1 (Unison/Detune) ---
		{
			unison_out: f32 = 0.0;
			unison_count := 1;
			for i in 0..<unison_count {
				detune_amount: f32 = 0.0;
				if unison_count > 1 do detune_amount = (f32(i) / (f32(unison_count) - 1.0) - 0.5) * 2.0 * (5.000000000);
				detuned_freq: f32 = ((voice.current_freq) * math.pow(2.0, math.clamp(f32(node_6_out), -10.0, 10.0))) * math.pow(2.0, detune_amount / 1200.0);
				phase_rads: f32 = f32(p.phase) * (f32(math.PI) / 180.0);
				voice.osc_1_phase[i] = math.mod(voice.osc_1_phase[i] + (2 * f32(math.PI) * detuned_freq / sample_rate), 2 * f32(math.PI));
				final_phase := math.mod(voice.osc_1_phase[i] + phase_rads, 2 * f32(math.PI));
				unison_out += ((final_phase / f32(math.PI)) - 1.0);
			}
			if unison_count > 0 do node_1_out = (unison_out / f32(unison_count)) * (p.Oscillator_amplitude);
		}

		// --- Filter Node 2 (SVF) ---
		{
			cutoff_c_2: f32 = math.clamp(f32((p.cutoff) + (node_5_out)), 10.0, sample_rate * 0.16);
			f_2 := f32(2.0 * math.sin(f32(math.PI) * cutoff_c_2 / sample_rate));
			q_2: f32 = math.clamp(1.0 / math.max(f32(p.resonance), 0.1), 0.05, 1.9 - f_2);
			voice.filter_2_low += f_2 * voice.filter_2_band;
			high_2 := f32(((node_1_out)) - voice.filter_2_low - q_2 * voice.filter_2_band);
			voice.filter_2_band += f_2 * high_2;
			node_2_out = voice.filter_2_low;
		}

		// --- ADSR Node 3 ---
		{
			envelope: f32 = 0.0;
			switch voice.adsr_3_stage {
			case .Idle:
				envelope = 0.0;
			case .Attack:
				if (p.ADSR_attack) > 0 do envelope = voice.age / math.max(f32(p.ADSR_attack), 0.000001); else do envelope = 1.0;
				voice.adsr_3_release_level = envelope;
				if voice.age >= (p.ADSR_attack) {
					voice.adsr_3_stage = .Decay;
				}
			case .Decay:
				time_in_decay := voice.age - (p.ADSR_attack);
				if (p.ADSR_decay) > 0 do envelope = 1.0 - (time_in_decay / math.max(f32(p.ADSR_decay), 0.000001)) * (1.0 - (p.ADSR_sustain)); else do envelope = (p.ADSR_sustain);
				voice.adsr_3_release_level = envelope;
				if time_in_decay >= (p.ADSR_decay) {
					voice.adsr_3_stage = .Sustain;
				}
			case .Sustain:
				envelope = (p.ADSR_sustain);
				voice.adsr_3_release_level = envelope;
				if envelope <= 0.0001 do voice.adsr_3_stage = .Idle;
			case .Release:
				time_in_release := voice.age - voice.time_released;
				if (p.ADSR_release) > 0 do envelope = voice.adsr_3_release_level * (1.0 - (time_in_release / math.max(f32(p.ADSR_release), 0.000001))); else do envelope = 0.0;
				if envelope <= 0 {
					envelope = 0;
					voice.adsr_3_stage = .Idle;
				}
			}
			vel_scale_3: f32 = (1.0 - (f32(0.700000000))) + (f32(0.700000000)) * voice.velocity;
			node_3_out = ((node_2_out)) * envelope * (p.ADSR_depth) * vel_scale_3;
		}

		output_left += node_3_out
		output_right += node_3_out
		if voice.adsr_3_stage != .Idle do voice_busy = true
		if voice.adsr_4_stage != .Idle do voice_busy = true
		if !voice_busy do voice.active = false
	}
	return output_left * f32(1.000000000), output_right * f32(1.000000000)
}
Tuba_process_sequence :: proc(p: ^Tuba_Processor) {
	if !p.playing do return
	samples_per_step_f := p.sample_rate * 60.0 / (p.bpm * 4.0)
	if p.samples_until_next_step == 0 {
		// Track "Tuba" (64 steps)
		switch p.current_step % 64 {
		case 0:
			Tuba_note_on(p, 60, 1.000000000, f32(3.000000000) * (60.0 / p.bpm / 4.0))
		case 5:
			Tuba_note_on(p, 60, 1.000000000, f32(2.000000000) * (60.0 / p.bpm / 4.0))
		case 8:
			Tuba_note_on(p, 60, 1.000000000, f32(2.000000000) * (60.0 / p.bpm / 4.0))
		case 11:
			Tuba_note_on(p, 60, 1.000000000, f32(3.000000000) * (60.0 / p.bpm / 4.0))
		}
		p.current_step += 1
		if p.current_step >= 16 {
			if p.loop {
				p.current_step = 0
			} else {
				p.playing = false
			}
		}
		p.step_frac_acc += samples_per_step_f
		n_step := u64(math.max(p.step_frac_acc, 1.0))
		p.step_frac_acc -= f32(n_step)
		p.samples_until_next_step = n_step - 1
	} else {
		p.samples_until_next_step -= 1
	}
}

// --- Project Wrapper (test-harness convenience) ---
Project_State :: struct {
	Bass: ^Bass_Processor,
	Bass_2: ^Bass_2_Processor,
	Bass_3: ^Bass_3_Processor,
	Tuba: ^Tuba_Processor,
}

project_init :: proc(p: ^Project_State, sr: f32) {
	p.Bass = new(Bass_Processor)
	Bass_init(p.Bass, sr)
	Bass_start(p.Bass)
	p.Bass_2 = new(Bass_2_Processor)
	Bass_2_init(p.Bass_2, sr)
	Bass_2_start(p.Bass_2)
	p.Bass_3 = new(Bass_3_Processor)
	Bass_3_init(p.Bass_3, sr)
	Bass_3_start(p.Bass_3)
	p.Tuba = new(Tuba_Processor)
	Tuba_init(p.Tuba, sr)
	Tuba_start(p.Tuba)
}

project_process :: proc(p: ^Project_State) -> (f32, f32) {
	mixed_left: f32 = 0.0
	mixed_right: f32 = 0.0
	{ l, r := Bass_process(p.Bass); mixed_left += l; mixed_right += r }
	{ l, r := Bass_2_process(p.Bass_2); mixed_left += l; mixed_right += r }
	{ l, r := Bass_3_process(p.Bass_3); mixed_left += l; mixed_right += r }
	{ l, r := Tuba_process(p.Tuba); mixed_left += l; mixed_right += r }
	mixed_left = math.tanh(mixed_left * 0.800000012)
	mixed_right = math.tanh(mixed_right * 0.800000012)
	return mixed_left, mixed_right
}

project_destroy :: proc(p: ^Project_State) {
	free(p.Bass)
	free(p.Bass_2)
	free(p.Bass_3)
	free(p.Tuba)
}

