package generated_audio

// =====================================================================
// Generated by Skald.
//
// SFX assets: (none)
// Music Layer assets: Bass Bass_2 Bass_3 Tuba
//
// Game integration: import this package and use the per-asset APIs.
//   SFX:         <Foo>_init, <Foo>_trigger, <Foo>_process, <Foo>_is_playing
//   Music Layer: <Bar>_init, <Bar>_start, <Bar>_stop, <Bar>_process,
//                <Bar>_set_loop
//
// <Foo>_trigger with duration<=0 (the default) plays a natural one-shot:
// the envelope holds through attack+decay, then releases (a patch with no
// envelope plays 1s). Pass an explicit duration in seconds to hold longer,
// or drive <Foo>_note_on / <Foo>_note_off yourself for full control.
//
// project_init/process/destroy is a convenience wrapper for the test
// harness only — game code should consume per-asset procs directly.
// =====================================================================

import "core:math"
import "core:math/rand"

PRNG_State :: struct {
	state: u32,
}

next_float32 :: proc(rng: ^PRNG_State) -> f32 {
	x := rng.state
	x ~= x << 13
	x ~= x >> 17
	x ~= x << 5
	if x == 0 do x = 0xDEADBEEF
	rng.state = x
	return f32(x) / 4294967296.0
}

ADSR_Stage :: enum { Idle, Attack, Decay, Sustain, Release }

skald_wavetable_shape :: proc(idx: int, ph: f32) -> f32 {
	switch idx {
	case 1: return abs(ph * 4.0 - 2.0) - 1.0
	case 2: return ph * 2.0 - 1.0
	case 3: return ph < 0.5 ? 1.0 : -1.0
	}
	return math.sin(ph * 2.0 * f32(math.PI))
}

skald_wavetable_sample :: proc(ph: f32, pos: f32) -> f32 {
	p := math.clamp(pos, 0.0, 3.0)
	i1 := int(p)
	i2 := (i1 + 1) % 4
	frac := p - f32(i1)
	s1 := skald_wavetable_shape(i1, ph)
	s2 := skald_wavetable_shape(i2, ph)
	return s1 + (s2 - s1) * frac
}

Note_Event :: struct {
	note: u8,
	velocity: f32,
	start_time: f32,
	step: int,
	duration: f32,
}

Skald_Param_Info :: struct {
	name:    string,
	min:     f32,
	max:     f32,
	default: f32,
	unit:    string,
}

Bass_Voice_State :: struct {
	active: bool,
	note: u8,
	velocity: f32,
	age: f32,
	time_released: f32,
	current_freq: f32,
	target_freq: f32,
	glide_time: f32,
	duration: f32,
	osc_1_phase: [1]f32,
	osc_2_phase: [1]f32,
	filter_4_low: f32,
	filter_4_band: f32,
	adsr_5_stage: ADSR_Stage,
	adsr_5_release_level: f32,
}

Bass_Processor :: struct {
	sample_rate: f32,
	bpm: f32,
	voices: [8]Bass_Voice_State,
	prng: PRNG_State,
	total_samples: u64,
	playing: bool,
	loop: bool,
	current_step: u64,
	samples_until_next_step: u64,
	step_frac_acc: f32,
	ext_in_l: f32,
	ext_in_r: f32,
	Oscillator_amplitude: f32,
	Oscillator_amplitude_2: f32,
	Oscillator_frequency: f32,
	Oscillator_frequency_2: f32,
	Oscillator_phase: f32,
	Oscillator_phase_2: f32,
	Oscillator_pulseWidth: f32,
	Oscillator_pulseWidth_2: f32,
	attack: f32,
	cutoff: f32,
	decay: f32,
	depth: f32,
	release: f32,
	resonance: f32,
	sustain: f32,
}

Bass_init :: proc(p: ^Bass_Processor, sr: f32) {
	p.sample_rate = sr
	p.bpm = 120.000000000
	p.prng.state = 12345
	p.loop = true
	p.Oscillator_amplitude = 0.500000000
	p.Oscillator_amplitude_2 = 0.500000000
	p.Oscillator_frequency = 440.000000000
	p.Oscillator_frequency_2 = 440.000000000
	p.Oscillator_phase = 0.000000000
	p.Oscillator_phase_2 = 0.000000000
	p.Oscillator_pulseWidth = 0.500000000
	p.Oscillator_pulseWidth_2 = 0.300000012
	p.attack = 0.005000000
	p.cutoff = 500.000000000
	p.decay = 0.150000006
	p.depth = 1.000000000
	p.release = 0.100000001
	p.resonance = 1.500000000
	p.sustain = 0.699999988
}

Bass_note_on :: proc(p: ^Bass_Processor, note: u8, velocity: f32, duration: f32) {
	voice_idx := -1
	for i in 0..<8 {
		if !p.voices[i].active {
			voice_idx = i
			break
		}
	}
	stolen := false
	if voice_idx == -1 {
		stolen = true
		oldest_age: f32 = -1.0
		for i in 0..<8 {
			if p.voices[i].age > oldest_age {
				oldest_age = p.voices[i].age
				voice_idx = i
			}
		}
	}

	v := &p.voices[voice_idx]
	prev_freq := v.current_freq
	v.active = true
	v.note = note
	v.velocity = velocity
	v.age = 0.0
	v.time_released = 0.0
	freq := 440.0 * math.pow(2.0, (f32(note) - 69.0) / 12.0)
	v.target_freq = freq
	v.glide_time = 0.050000001
	if stolen && v.glide_time > 0.0 && prev_freq > 0.0 {
		v.current_freq = prev_freq
	} else {
		v.current_freq = freq
	}
	v.duration = duration
	v.osc_1_phase = {}
	v.osc_2_phase = {}
	v.filter_4_low = 0.0
	v.filter_4_band = 0.0
	v.adsr_5_stage = .Attack
	v.adsr_5_release_level = 0.0
}

Bass_note_off :: proc(p: ^Bass_Processor, note: u8) {
	best := -1
	best_age: f32 = -1.0
	for i in 0..<8 {
		if p.voices[i].active && p.voices[i].note == note {
			if p.voices[i].adsr_5_stage == .Release do continue
			if p.voices[i].age > best_age {
				best_age = p.voices[i].age
				best = i
			}
		}
	}
	if best >= 0 {
		p.voices[best].time_released = p.voices[best].age
		p.voices[best].adsr_5_stage = .Release
	}
}

Bass_trigger :: proc(p: ^Bass_Processor, note: u8 = 60, velocity: f32 = 1.0, duration: f32 = 0.0) {
	d := duration
	if d <= 0.0 {
		d = 0.0
		if (p.attack) + (p.decay) > d do d = (p.attack) + (p.decay)
		if d <= 0.0 do d = 0.001
	}
	Bass_note_on(p, note, velocity, d)
}

Bass_feed_input :: proc(p: ^Bass_Processor, in_left: f32, in_right: f32) {
	p.ext_in_l = in_left
	p.ext_in_r = in_right
}

Bass_start :: proc(p: ^Bass_Processor) {
	p.playing = true
	p.current_step = 0
	p.samples_until_next_step = 0
	p.step_frac_acc = 0.0
}

Bass_stop :: proc(p: ^Bass_Processor) {
	p.playing = false
}

Bass_set_loop :: proc(p: ^Bass_Processor, loop: bool) {
	p.loop = loop
}

Bass_is_playing :: proc(p: ^Bass_Processor) -> bool {
	if p.playing do return true
	for i in 0..<8 {
		if p.voices[i].active do return true
	}
	return false
}

