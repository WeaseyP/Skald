}

Bass_init :: proc(p: ^Bass_Processor, sr: f32) {
	p.sample_rate = sr
	p.bpm = 120.000
	p.prng.state = 12345
	p.loop = true
	p.decay = 0.200
	p.release = 1.000
	p.pulseWidth = 0.500
	p.frequency = 28.842
	p.amplitude = 0.500
	p.resonance = 1.000
	p.phase = 0.000
	p.sustain = 0.500
	p.depth = 1.000
	p.cutoff = 800.000
	p.attack = 0.100
}

Bass_note_on :: proc(p: ^Bass_Processor, note: u8, velocity: f32, duration: f32) {
	voice_idx := -1
	for i in 0..<8 {
		if !p.voices[i].active {
			voice_idx = i
			break
		}
	}
	stolen := false
	if voice_idx == -1 {
		stolen = true
		oldest_age: f32 = -1.0
		for i in 0..<8 {
			if p.voices[i].age > oldest_age {
				oldest_age = p.voices[i].age
				voice_idx = i
			}
		}
	}

	v := &p.voices[voice_idx]
	prev_freq := v.current_freq
	v.active = true
	v.note = note
	v.velocity = velocity
	v.age = 0.0
	v.time_released = 0.0
	freq := 440.0 * math.pow(2.0, (f32(note) - 69.0) / 12.0)
	v.target_freq = freq
	v.glide_time = 0.050
	if stolen && v.glide_time > 0.0 && prev_freq > 0.0 {
		v.current_freq = prev_freq
	} else {
		v.current_freq = freq
	}
	v.duration = duration
	v.filter_2_low = 0.0
	v.filter_2_band = 0.0
	v.osc_1_phase = {}
	v.adsr_3_stage = .Attack
	v.adsr_3_release_level = 0.0
}

Bass_note_off :: proc(p: ^Bass_Processor, note: u8) {
	best := -1
	best_age: f32 = -1.0
	for i in 0..<8 {
		if p.voices[i].active && p.voices[i].note == note {
			if p.voices[i].adsr_3_stage == .Release do continue
			if p.voices[i].age > best_age {
				best_age = p.voices[i].age
				best = i
			}
		}
	}
	if best >= 0 {
		p.voices[best].time_released = p.voices[best].age
		p.voices[best].adsr_3_stage = .Release
	}
}

Bass_trigger :: proc(p: ^Bass_Processor, note: u8 = 60, velocity: f32 = 1.0, duration: f32 = 0.0) {
	Bass_note_on(p, note, velocity, duration)
}

Bass_start :: proc(p: ^Bass_Processor) {
	p.playing = true
	p.current_step = 0
	p.samples_until_next_step = 0
	p.step_frac_acc = 0.0
}

Bass_stop :: proc(p: ^Bass_Processor) {
	p.playing = false
}

Bass_set_loop :: proc(p: ^Bass_Processor, loop: bool) {
	p.loop = loop
}

Bass_is_playing :: proc(p: ^Bass_Processor) -> bool {
	if p.playing do return true
	for i in 0..<8 {
		if p.voices[i].active do return true
	}
	return false
}

