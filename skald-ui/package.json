{
  "name": "skald",
  "productName": "Skald",
  "version": "0.1.0",
  "description": "Visual audio programming and Odin code generation for games",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:codegen": "cd ../skald-backend && build_codegen.bat",
    "start:rebuild": "npm run build:codegen && electron-forge start",
    "setup:dev": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ../scripts/setup-dev.ps1",
    "release:win": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ../scripts/build-release.ps1",
    "make:win": "electron-forge make --platform=win32 --arch=x64"
  },
  "keywords": [
    "audio",
    "odin",
    "electron",
    "synthesis"
  ],
  "engines": {
    "node": ">=22"
  },
  "author": {
    "name": "Ryan Parsons",
    "email": "ryanparsons10101@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-squirrel": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@electron-forge/plugin-fuses": "^7.8.1",
    "@electron-forge/plugin-vite": "^7.8.1",
    "@electron/fuses": "^1.8.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^43.2.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.31.0",
    "happy-dom": "^20.0.11",
    "jsdom": "^27.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "reactflow": "^11.11.4",
    "use-deep-compare-effect": "^1.8.1"
  }
}
