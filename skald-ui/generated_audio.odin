import "core:math"
import "core:math/rand"

PRNG_State :: struct {
	state: u32,
}

next_float32 :: proc(rng: ^PRNG_State) -> f32 {
	x := rng.state
	x ~= x << 13
	x ~= x >> 17
	x ~= x << 5
	if x == 0 do x = 0xDEADBEEF
	rng.state = x
	return f32(x) / 4294967296.0
}

ADSR_Stage :: enum { Idle, Attack, Decay, Sustain, Release }

skald_wavetable_shape :: proc(idx: int, ph: f32) -> f32 {
	switch idx {
	case 1: return abs(ph * 4.0 - 2.0) - 1.0
	case 2: return ph * 2.0 - 1.0
	case 3: return ph < 0.5 ? 1.0 : -1.0
	}
	return math.sin(ph * 2.0 * f32(math.PI))
}

skald_wavetable_sample :: proc(ph: f32, pos: f32) -> f32 {
	p := math.clamp(pos, 0.0, 3.0)
	i1 := int(p)
	i2 := (i1 + 1) % 4
	frac := p - f32(i1)
	s1 := skald_wavetable_shape(i1, ph)
	s2 := skald_wavetable_shape(i2, ph)
	return s1 + (s2 - s1) * frac
}

Note_Event :: struct {
	note: u8,
	velocity: f32,
	start_time: f32,
	step: int,
	duration: f32,
}

Skald_Param_Info :: struct {
	name:    string,
	min:     f32,
	max:     f32,
	default: f32,
	unit:    string,
}

Kick_Voice_State :: struct {
	active: bool,
	note: u8,
	velocity: f32,
	age: f32,
	time_released: f32,
	current_freq: f32,
	target_freq: f32,
	glide_time: f32,
	duration: f32,
	adsr_3_stage: ADSR_Stage,
	adsr_3_release_level: f32,
	osc_1_phase: [1]f32,
	dist_4_tone: f32,
	adsr_2_stage: ADSR_Stage,
	adsr_2_release_level: f32,
}

Kick_Processor :: struct {
	sample_rate: f32,
	bpm: f32,
	voices: [8]Kick_Voice_State,
	prng: PRNG_State,
	total_samples: u64,
	playing: bool,
	loop: bool,
	current_step: u64,
	samples_until_next_step: u64,
	step_frac_acc: f32,
	n2_decay: f32,
	frequency: f32,
	n2_release: f32,
	tone: f32,
	n3_sustain: f32,
	n2_sustain: f32,
	n2_depth: f32,
	amplitude: f32,
	n3_depth: f32,
	drive: f32,
	n3_decay: f32,
	n3_release: f32,
	mix: f32,
	n2_attack: f32,
	phase: f32,
	n3_attack: f32,
	pulseWidth: f32,
}

Kick_init :: proc(p: ^Kick_Processor, sr: f32) {
	p.sample_rate = sr
	p.bpm = 120.000
	p.prng.state = 12345
	p.loop = true
	p.n2_decay = 0.052
	p.frequency = 121.350
	p.n2_release = 0.001
	p.tone = 4000.000
	p.n3_sustain = 0.011
	p.n2_sustain = 0.000
	p.n2_depth = 1.000
	p.amplitude = 0.500
	p.n3_depth = 1.000
	p.drive = 5.000
	p.n3_decay = 0.052
	p.n3_release = 0.133
	p.mix = 0.500
	p.n2_attack = 0.001
	p.phase = 0.000
	p.n3_attack = 0.001
	p.pulseWidth = 0.500
}

Kick_note_on :: proc(p: ^Kick_Processor, note: u8, velocity: f32, duration: f32) {
	voice_idx := -1
	for i in 0..<8 {
		if !p.voices[i].active {
			voice_idx = i
			break
		}
	}
	stolen := false
	if voice_idx == -1 {
		stolen = true
		oldest_age: f32 = -1.0
		for i in 0..<8 {
			if p.voices[i].age > oldest_age {
				oldest_age = p.voices[i].age
				voice_idx = i
			}
		}
	}

	v := &p.voices[voice_idx]
	prev_freq := v.current_freq
	v.active = true
	v.note = note
	v.velocity = velocity
	v.age = 0.0
	v.time_released = 0.0
	freq := 440.0 * math.pow(2.0, (f32(note) - 69.0) / 12.0)
	v.target_freq = freq
	v.glide_time = 0.050
	if stolen && v.glide_time > 0.0 && prev_freq > 0.0 {
		v.current_freq = prev_freq
	} else {
		v.current_freq = freq
	}
	v.duration = duration
	v.adsr_3_stage = .Attack
	v.adsr_3_release_level = 0.0
	v.osc_1_phase = {}
	v.dist_4_tone = 0.0
	v.adsr_2_stage = .Attack
	v.adsr_2_release_level = 0.0
}

Kick_note_off :: proc(p: ^Kick_Processor, note: u8) {
	best := -1
	best_age: f32 = -1.0
	for i in 0..<8 {
		if p.voices[i].active && p.voices[i].note == note {
			if p.voices[i].adsr_3_stage == .Release do continue
			if p.voices[i].age > best_age {
				best_age = p.voices[i].age
				best = i
			}
		}
	}
	if best >= 0 {
		p.voices[best].time_released = p.voices[best].age
		p.voices[best].adsr_3_stage = .Release
		p.voices[best].adsr_2_stage = .Release
	}
}

Kick_trigger :: proc(p: ^Kick_Processor, note: u8 = 60, velocity: f32 = 1.0, duration: f32 = 0.0) {
	Kick_note_on(p, note, velocity, duration)
}

Kick_start :: proc(p: ^Kick_Processor) {
	p.playing = true
	p.current_step = 0
	p.samples_until_next_step = 0
	p.step_frac_acc = 0.0
}

Kick_stop :: proc(p: ^Kick_Processor) {
	p.playing = false
}

Kick_set_loop :: proc(p: ^Kick_Processor, loop: bool) {
	p.loop = loop
}

Kick_is_playing :: proc(p: ^Kick_Processor) -> bool {
	if p.playing do return true
	for i in 0..<8 {
		if p.voices[i].active do return true
	}
	return false
}

