Snare_Drum_PARAMS := []Skald_Param_Info{
	{"pulseWidth", 0.000, 1.000, 0.500, ""},
	{"resonance", 0.100, 20.000, 0.593, "Q"},
	{"depth", 0.000, 1.000, 1.000, ""},
	{"n3_amplitude", 0.000, 1.000, 0.500, ""},
	{"attack", 0.001, 10.000, 0.001, "s"},
	{"frequency", 20.000, 20000.000, 220.000, "Hz"},
	{"n1_amplitude", 0.000, 1.000, 1.000, ""},
	{"decay", 0.001, 10.000, 0.159, "s"},
	{"sustain", 0.000, 1.000, 0.000, ""},
	{"release", 0.001, 10.000, 0.133, "s"},
	{"cutoff", 20.000, 20000.000, 2449.232, "Hz"},
	{"phase", 0.000, 360.000, 0.000, "deg"},
}

Snare_Drum_set_param :: proc(p: ^Snare_Drum_Processor, name: string, value: f32) -> bool {
	switch name {
	case "pulseWidth":
		Snare_Drum_set_pulseWidth(p, value)
		return true
	case "resonance":
		Snare_Drum_set_resonance(p, value)
		return true
	case "depth":
		Snare_Drum_set_depth(p, value)
		return true
	case "n3_amplitude":
		Snare_Drum_set_n3_amplitude(p, value)
		return true
	case "attack":
		Snare_Drum_set_attack(p, value)
		return true
	case "frequency":
		Snare_Drum_set_frequency(p, value)
		return true
	case "n1_amplitude":
		Snare_Drum_set_n1_amplitude(p, value)
		return true
	case "decay":
		Snare_Drum_set_decay(p, value)
		return true
	case "sustain":
		Snare_Drum_set_sustain(p, value)
		return true
	case "release":
		Snare_Drum_set_release(p, value)
		return true
	case "cutoff":
		Snare_Drum_set_cutoff(p, value)
		return true
	case "phase":
		Snare_Drum_set_phase(p, value)
		return true
	}
	return false
}

Snare_Drum_get_param :: proc(p: ^Snare_Drum_Processor, name: string) -> (f32, bool) {
	switch name {
	case "pulseWidth":
		return p.pulseWidth, true
	case "resonance":
		return p.resonance, true
	case "depth":
		return p.depth, true
	case "n3_amplitude":
		return p.n3_amplitude, true
	case "attack":
		return p.attack, true
	case "frequency":
		return p.frequency, true
	case "n1_amplitude":
		return p.n1_amplitude, true
	case "decay":
		return p.decay, true
	case "sustain":
		return p.sustain, true
	case "release":
		return p.release, true
	case "cutoff":
		return p.cutoff, true
	case "phase":
		return p.phase, true
	}
	return 0.0, false
}

Snare_Drum_process :: proc(p: ^Snare_Drum_Processor) -> (f32, f32) {
	sample_rate := p.sample_rate
	output_left: f32 = 0.0
	output_right: f32 = 0.0
	Snare_Drum_process_sequence(p)
	p.total_samples += 1

	for v_idx in 0..<8 {
		voice := &p.voices[v_idx]
		if !voice.active do continue

		voice.age += 1.0 / sample_rate;
		if voice.current_freq != voice.target_freq {
			glide_k := 1.0 / math.max(voice.glide_time * sample_rate, 1.0)
			if glide_k > 1.0 do glide_k = 1.0
			voice.current_freq += (voice.target_freq - voice.current_freq) * glide_k
			if abs(voice.target_freq - voice.current_freq) < 0.1 do voice.current_freq = voice.target_freq
		}
		if voice.age >= voice.duration && voice.duration > 0.0 {
			if voice.adsr_5_stage != .Release && voice.adsr_5_stage != .Idle {
				voice.adsr_5_stage = .Release
				voice.time_released = voice.age
			}
		}
		voice_busy := false
		node_3_out: f32 = 0.0
		node_6_out: f32 = 0.0
		node_1_out: f32 = 0.0
		node_4_out: f32 = 0.0
		node_2_out: f32 = 0.0
		node_5_out: f32 = 0.0

		// --- Noise Node 1 ---
		node_1_out = (next_float32(&voice.noise_1_rng) * 2.0 - 1.0) * (p.n1_amplitude);

		// --- Oscillator Node 3 (Unison/Detune) ---
		{
			unison_out: f32 = 0.0;
			unison_count := 1;
			for i in 0..<unison_count {
				detune_amount: f32 = 0.0;
				if unison_count > 1 do detune_amount = (f32(i) / (f32(unison_count) - 1.0) - 0.5) * 2.0 * (5.000);
				detuned_freq := (voice.current_freq) * math.pow(2.0, detune_amount / 1200.0);
				phase_rads := f32(p.phase) * (f32(math.PI) / 180.0);
				voice.osc_3_phase[i] = math.mod(voice.osc_3_phase[i] + (2 * f32(math.PI) * detuned_freq / sample_rate), 2 * f32(math.PI));
				final_phase := math.mod(voice.osc_3_phase[i] + phase_rads, 2 * f32(math.PI));
				unison_out += (2.0 / f32(math.PI)) * math.asin(math.sin(final_phase));
			}
			if unison_count > 0 do node_3_out = (unison_out / f32(unison_count)) * (p.n3_amplitude);
		}

		// --- Mixer Node 2 (4 inputs) ---
		{
			mix_sum_2: f32 = 0.0;
			mix_sum_2 += node_1_out * (0.750);
			mix_sum_2 += node_3_out * (0.750);
		node_2_out = mix_sum_2;
		}

		// --- Filter Node 4 (SVF) ---
		{
			cutoff_c_4 := math.clamp(f32(p.cutoff), 10.0, sample_rate * 0.16);
			f_4 := f32(2.0 * math.sin(f32(math.PI) * cutoff_c_4 / sample_rate));
			q_4 := math.clamp(1.0 / math.max(f32(p.resonance), 0.1), 0.05, 1.9 - f_4);
			voice.filter_4_low += f_4 * voice.filter_4_band;
			high_4 := f32(((node_2_out)) - voice.filter_4_low - q_4 * voice.filter_4_band);
			voice.filter_4_band += f_4 * high_4;
			node_4_out = voice.filter_4_band;
		}

		// --- ADSR Node 5 ---
		{
			envelope: f32 = 0.0;
			switch voice.adsr_5_stage {
			case .Idle:
				envelope = 0.0;
			case .Attack:
				if (p.attack) > 0 do envelope = voice.age / math.max(f32(p.attack), 0.000001); else do envelope = 1.0;
				voice.adsr_5_release_level = envelope;
				if voice.age >= (p.attack) {
					voice.adsr_5_stage = .Decay;
				}
			case .Decay:
				time_in_decay := voice.age - (p.attack);
				if (p.decay) > 0 do envelope = 1.0 - (time_in_decay / math.max(f32(p.decay), 0.000001)) * (1.0 - (p.sustain)); else do envelope = (p.sustain);
				voice.adsr_5_release_level = envelope;
				if time_in_decay >= (p.decay) {
					voice.adsr_5_stage = .Sustain;
				}
			case .Sustain:
				envelope = (p.sustain);
				voice.adsr_5_release_level = envelope;
				if envelope <= 0.0001 do voice.adsr_5_stage = .Idle;
			case .Release:
				time_in_release := voice.age - voice.time_released;
				if (p.release) > 0 do envelope = voice.adsr_5_release_level * (1.0 - (time_in_release / math.max(f32(p.release), 0.000001))); else do envelope = 0.0;
				if envelope <= 0 {
					envelope = 0;
					voice.adsr_5_stage = .Idle;
				}
			}
			vel_scale_5 := (1.0 - (0.500)) + (0.500) * voice.velocity;
			node_5_out = ((node_4_out)) * envelope * (p.depth) * vel_scale_5;
		}

		output_left += node_5_out
		output_right += node_5_out
		if voice.adsr_5_stage != .Idle do voice_busy = true
		if !voice_busy do voice.active = false
	}
	return output_left, output_right
}
Snare_Drum_process_sequence :: proc(p: ^Snare_Drum_Processor) {
	if !p.playing do return
	samples_per_step_f := p.sample_rate * 60.0 / (p.bpm * 4.0)
	if p.samples_until_next_step == 0 {
		switch p.current_step % 32 {
		case 1:
			Snare_Drum_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 3:
			Snare_Drum_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 5:
			Snare_Drum_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 6:
			Snare_Drum_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 8:
			Snare_Drum_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 10:
			Snare_Drum_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 12:
			Snare_Drum_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 13:
			Snare_Drum_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 16:
			Snare_Drum_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 20:
			Snare_Drum_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 24:
			Snare_Drum_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 26:
			Snare_Drum_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 28:
			Snare_Drum_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		}
		p.current_step += 1
		if p.current_step >= 16 {
			if p.loop {
				p.current_step = 0
			} else {
				p.playing = false
			}
		}
		p.step_frac_acc += samples_per_step_f
		n_step := u64(math.max(p.step_frac_acc, 1.0))
		p.step_frac_acc -= f32(n_step)
		p.samples_until_next_step = n_step - 1
	} else {
		p.samples_until_next_step -= 1
	}
}

sax_Voice_State :: struct {
	active: bool,
	note: u8,
	velocity: f32,
	age: f32,
	time_released: f32,
	current_freq: f32,
	target_freq: f32,
	glide_time: f32,
	duration: f32,
	filter_3_low: f32,
	filter_3_band: f32,
	osc_2_phase: [1]f32,
	adsr_7_stage: ADSR_Stage,
	adsr_7_release_level: f32,
}

sax_Processor :: struct {
	sample_rate: f32,
	bpm: f32,
	voices: [8]sax_Voice_State,
	prng: PRNG_State,
	total_samples: u64,
	playing: bool,
	loop: bool,
	current_step: u64,
	samples_until_next_step: u64,
	step_frac_acc: f32,
	gain: f32,
	pulseWidth: f32,
	sustain: f32,
	useMpe: f32,
	frequency: f32,
	amplitude: f32,
	device: f32,
	cutoff: f32,
	release: f32,
	depth: f32,
	attack: f32,
	resonance: f32,
	decay: f32,
	phase: f32,
}

sax_init :: proc(p: ^sax_Processor, sr: f32) {
	p.sample_rate = sr
	p.bpm = 120.000
	p.prng.state = 12345
	p.loop = true
	p.gain = 0.000
	p.pulseWidth = 0.500
	p.sustain = 0.819
	p.useMpe = 0.000
	p.frequency = 440.000
	p.amplitude = 0.500
	p.device = 0.000
	p.cutoff = 857.097
	p.release = 0.213
	p.depth = 1.000
	p.attack = 0.053
	p.resonance = 1.910
	p.decay = 0.240
	p.phase = 0.000
}

sax_note_on :: proc(p: ^sax_Processor, note: u8, velocity: f32, duration: f32) {
	voice_idx := -1
	for i in 0..<8 {
		if !p.voices[i].active {
			voice_idx = i
			break
		}
	}
	stolen := false
	if voice_idx == -1 {
		stolen = true
		oldest_age: f32 = -1.0
		for i in 0..<8 {
			if p.voices[i].age > oldest_age {
				oldest_age = p.voices[i].age
				voice_idx = i
			}
		}
	}

	v := &p.voices[voice_idx]
	prev_freq := v.current_freq
	v.active = true
	v.note = note
	v.velocity = velocity
	v.age = 0.0
	v.time_released = 0.0
	freq := 440.0 * math.pow(2.0, (f32(note) - 69.0) / 12.0)
	v.target_freq = freq
	v.glide_time = 0.050
	if stolen && v.glide_time > 0.0 && prev_freq > 0.0 {
		v.current_freq = prev_freq
	} else {
		v.current_freq = freq
	}
	v.duration = duration
	v.filter_3_low = 0.0
	v.filter_3_band = 0.0
	v.osc_2_phase = {}
	v.adsr_7_stage = .Attack
	v.adsr_7_release_level = 0.0
}

sax_note_off :: proc(p: ^sax_Processor, note: u8) {
	best := -1
	best_age: f32 = -1.0
	for i in 0..<8 {
		if p.voices[i].active && p.voices[i].note == note {
			if p.voices[i].adsr_7_stage == .Release do continue
			if p.voices[i].age > best_age {
				best_age = p.voices[i].age
				best = i
			}
		}
	}
	if best >= 0 {
		p.voices[best].time_released = p.voices[best].age
		p.voices[best].adsr_7_stage = .Release
	}
}

sax_trigger :: proc(p: ^sax_Processor, note: u8 = 60, velocity: f32 = 1.0, duration: f32 = 0.0) {
	sax_note_on(p, note, velocity, duration)
}

sax_start :: proc(p: ^sax_Processor) {
	p.playing = true
	p.current_step = 0
	p.samples_until_next_step = 0
	p.step_frac_acc = 0.0
}

sax_stop :: proc(p: ^sax_Processor) {
	p.playing = false
}

sax_set_loop :: proc(p: ^sax_Processor, loop: bool) {
	p.loop = loop
}

sax_is_playing :: proc(p: ^sax_Processor) -> bool {
	if p.playing do return true
	for i in 0..<8 {
		if p.voices[i].active do return true
	}
	return false
}

sax_set_gain :: proc(p: ^sax_Processor, value: f32) {
	v := value
	if v < 0.000 do v = 0.000
	if v > 4.000 do v = 4.000
	p.gain = v
}

sax_set_pulseWidth :: proc(p: ^sax_Processor, value: f32) {
	v := value
	if v < 0.000 do v = 0.000
	if v > 1.000 do v = 1.000
	p.pulseWidth = v
}

