}

sax_set_cutoff :: proc(p: ^sax_Processor, value: f32) {
	v := value
	if v < 20.000 do v = 20.000
	if v > 20000.000 do v = 20000.000
	p.cutoff = v
}

sax_set_release :: proc(p: ^sax_Processor, value: f32) {
	v := value
	if v < 0.001 do v = 0.001
