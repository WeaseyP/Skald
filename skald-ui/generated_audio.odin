sax_PARAMS := []Skald_Param_Info{
	{"gain", 0.000, 4.000, 0.000, "x"},
	{"pulseWidth", 0.000, 1.000, 0.500, ""},
	{"sustain", 0.000, 1.000, 0.819, ""},
	{"useMpe", -1000000.000, 1000000.000, 0.000, ""},
	{"frequency", 20.000, 20000.000, 440.000, "Hz"},
	{"amplitude", 0.000, 1.000, 0.500, ""},
	{"device", -1000000.000, 1000000.000, 0.000, ""},
	{"cutoff", 20.000, 20000.000, 857.097, "Hz"},
	{"release", 0.001, 10.000, 0.213, "s"},
	{"depth", 0.000, 1.000, 1.000, ""},
	{"attack", 0.001, 10.000, 0.053, "s"},
	{"resonance", 0.100, 20.000, 1.910, "Q"},
	{"decay", 0.001, 10.000, 0.240, "s"},
	{"phase", 0.000, 360.000, 0.000, "deg"},
}

sax_set_param :: proc(p: ^sax_Processor, name: string, value: f32) -> bool {
	switch name {
	case "gain":
		sax_set_gain(p, value)
		return true
	case "pulseWidth":
		sax_set_pulseWidth(p, value)
		return true
	case "sustain":
		sax_set_sustain(p, value)
		return true
	case "useMpe":
		sax_set_useMpe(p, value)
		return true
	case "frequency":
		sax_set_frequency(p, value)
		return true
	case "amplitude":
		sax_set_amplitude(p, value)
		return true
	case "device":
		sax_set_device(p, value)
		return true
	case "cutoff":
		sax_set_cutoff(p, value)
		return true
	case "release":
		sax_set_release(p, value)
		return true
	case "depth":
		sax_set_depth(p, value)
		return true
	case "attack":
		sax_set_attack(p, value)
		return true
	case "resonance":
		sax_set_resonance(p, value)
		return true
	case "decay":
		sax_set_decay(p, value)
		return true
	case "phase":
		sax_set_phase(p, value)
		return true
	}
	return false
}

sax_get_param :: proc(p: ^sax_Processor, name: string) -> (f32, bool) {
	switch name {
	case "gain":
		return p.gain, true
	case "pulseWidth":
		return p.pulseWidth, true
	case "sustain":
		return p.sustain, true
	case "useMpe":
		return p.useMpe, true
	case "frequency":
		return p.frequency, true
	case "amplitude":
		return p.amplitude, true
	case "device":
		return p.device, true
	case "cutoff":
		return p.cutoff, true
	case "release":
		return p.release, true
	case "depth":
		return p.depth, true
	case "attack":
		return p.attack, true
	case "resonance":
		return p.resonance, true
	case "decay":
		return p.decay, true
	case "phase":
		return p.phase, true
	}
	return 0.0, false
}

sax_process :: proc(p: ^sax_Processor) -> (f32, f32) {
	sample_rate := p.sample_rate
	output_left: f32 = 0.0
	output_right: f32 = 0.0
	sax_process_sequence(p)
	p.total_samples += 1

	for v_idx in 0..<8 {
		voice := &p.voices[v_idx]
		if !voice.active do continue

		voice.age += 1.0 / sample_rate;
		if voice.current_freq != voice.target_freq {
			glide_k := 1.0 / math.max(voice.glide_time * sample_rate, 1.0)
			if glide_k > 1.0 do glide_k = 1.0
			voice.current_freq += (voice.target_freq - voice.current_freq) * glide_k
			if abs(voice.target_freq - voice.current_freq) < 0.1 do voice.current_freq = voice.target_freq
		}
		if voice.age >= voice.duration && voice.duration > 0.0 {
			if voice.adsr_7_stage != .Release && voice.adsr_7_stage != .Idle {
				voice.adsr_7_stage = .Release
				voice.time_released = voice.age
			}
		}
		voice_busy := false
		node_4_out: f32 = 0.0
		node_3_out: f32 = 0.0
		node_2_out: f32 = 0.0
		node_7_out: f32 = 0.0
		node_1_out: f32 = 0.0
		node_6_out: f32 = 0.0
		node_5_out: f32 = 0.0

		// --- MIDI Input Node 6 ---
		node_6_out_pitch := (f32(voice.note) - 69.0) / 12.0
		node_6_out_gate := f32(1.0)
		if voice.time_released > 0.0 do node_6_out_gate = 0.0
		node_6_out_velocity := voice.velocity

		// --- Oscillator Node 2 (Unison/Detune) ---
		{
			unison_out: f32 = 0.0;
			unison_count := 1;
			for i in 0..<unison_count {
				detune_amount: f32 = 0.0;
				if unison_count > 1 do detune_amount = (f32(i) / (f32(unison_count) - 1.0) - 0.5) * 2.0 * (5.000);
				detuned_freq := ((voice.current_freq) * math.pow(2.0, math.clamp(f32(node_6_out_pitch), -10.0, 10.0))) * math.pow(2.0, detune_amount / 1200.0);
				phase_rads := f32(p.phase) * (f32(math.PI) / 180.0);
				voice.osc_2_phase[i] = math.mod(voice.osc_2_phase[i] + (2 * f32(math.PI) * detuned_freq / sample_rate), 2 * f32(math.PI));
				final_phase := math.mod(voice.osc_2_phase[i] + phase_rads, 2 * f32(math.PI));
				unison_out += ((final_phase / f32(math.PI)) - 1.0);
			}
			if unison_count > 0 do node_2_out = (unison_out / f32(unison_count)) * (p.amplitude);
		}

		// --- ADSR Node 7 ---
		{
			envelope: f32 = 0.0;
			switch voice.adsr_7_stage {
			case .Idle:
				envelope = 0.0;
			case .Attack:
				if (p.attack) > 0 do envelope = voice.age / math.max(f32(p.attack), 0.000001); else do envelope = 1.0;
				voice.adsr_7_release_level = envelope;
				if voice.age >= (p.attack) {
					voice.adsr_7_stage = .Decay;
				}
			case .Decay:
				time_in_decay := voice.age - (p.attack);
				if (p.decay) > 0 do envelope = 1.0 - (time_in_decay / math.max(f32(p.decay), 0.000001)) * (1.0 - (p.sustain)); else do envelope = (p.sustain);
				voice.adsr_7_release_level = envelope;
				if time_in_decay >= (p.decay) {
					voice.adsr_7_stage = .Sustain;
				}
			case .Sustain:
				envelope = (p.sustain);
				voice.adsr_7_release_level = envelope;
				if envelope <= 0.0001 do voice.adsr_7_stage = .Idle;
			case .Release:
				time_in_release := voice.age - voice.time_released;
				if (p.release) > 0 do envelope = voice.adsr_7_release_level * (1.0 - (time_in_release / math.max(f32(p.release), 0.000001))); else do envelope = 0.0;
				if envelope <= 0 {
					envelope = 0;
					voice.adsr_7_stage = .Idle;
				}
			}
			vel_scale_7 := (1.0 - (0.500)) + (0.500) * voice.velocity;
			node_7_out = ((node_6_out_gate)) * envelope * (p.depth) * vel_scale_7;
		}

		// --- Mapper Node 1 ---
		{
			in_range_1 := f32(1.000) - f32(0.000);
			if in_range_1 == 0.0 do in_range_1 = 1.0;
			node_1_out = math.lerp(f32(400.000), f32(3000.000), math.clamp((f32((node_6_out_velocity)) - f32(0.000)) / in_range_1, 0.0, 1.0));
		}

		// --- Filter Node 3 (SVF) ---
		{
			cutoff_c_3 := math.clamp(f32((p.cutoff) + (node_7_out) + (node_1_out)), 10.0, sample_rate * 0.16);
			f_3 := f32(2.0 * math.sin(f32(math.PI) * cutoff_c_3 / sample_rate));
			q_3 := math.clamp(1.0 / math.max(f32(p.resonance), 0.1), 0.05, 1.9 - f_3);
			voice.filter_3_low += f_3 * voice.filter_3_band;
			high_3 := f32(((node_2_out)) - voice.filter_3_low - q_3 * voice.filter_3_band);
			voice.filter_3_band += f_3 * high_3;
			node_3_out = voice.filter_3_low;
		}

		// --- Gain Node 4 ---
		node_4_out = ((node_3_out)) * ((p.gain) + (node_7_out));

		output_left += node_4_out
		output_right += node_4_out
		if voice.adsr_7_stage != .Idle do voice_busy = true
		if !voice_busy do voice.active = false
	}
	return output_left, output_right
}
sax_process_sequence :: proc(p: ^sax_Processor) {
	if !p.playing do return
	samples_per_step_f := p.sample_rate * 60.0 / (p.bpm * 4.0)
	if p.samples_until_next_step == 0 {
		switch p.current_step % 32 {
		case 0:
			sax_set_param(p, "Oscillator:frequency", 52.605)
			sax_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 1:
			sax_set_param(p, "Oscillator:frequency", 59.983)
			sax_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 3:
			sax_set_param(p, "Oscillator:frequency", 133.670)
			sax_note_on(p, 60, 1.000, f32(3.000) * (60.0 / p.bpm / 4.0))
		case 7:
			sax_set_param(p, "Oscillator:frequency", 52.605)
			sax_note_on(p, 60, 1.000, f32(2.000) * (60.0 / p.bpm / 4.0))
		case 10:
			sax_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 11:
			sax_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 13:
			sax_set_param(p, "Oscillator:frequency", 133.670)
			sax_note_on(p, 60, 1.000, f32(2.000) * (60.0 / p.bpm / 4.0))
		case 16:
			sax_note_on(p, 60, 1.000, f32(3.000) * (60.0 / p.bpm / 4.0))
		case 20:
			sax_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 21:
			sax_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 22:
			sax_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 24:
			sax_note_on(p, 60, 1.000, f32(3.000) * (60.0 / p.bpm / 4.0))
		case 27:
			sax_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 28:
			sax_note_on(p, 60, 1.000, f32(3.000) * (60.0 / p.bpm / 4.0))
		}
		p.current_step += 1
		if p.current_step >= 16 {
			if p.loop {
				p.current_step = 0
			} else {
				p.playing = false
			}
		}
		p.step_frac_acc += samples_per_step_f
		n_step := u64(math.max(p.step_frac_acc, 1.0))
		p.step_frac_acc -= f32(n_step)
		p.samples_until_next_step = n_step - 1
	} else {
		p.samples_until_next_step -= 1
	}
}

// --- Project Wrapper (test-harness convenience) ---
Project_State :: struct {
	Kick: ^Kick_Processor,
	Snare_Drum: ^Snare_Drum_Processor,
	sax: ^sax_Processor,
}

project_init :: proc(p: ^Project_State, sr: f32) {
	p.Kick = new(Kick_Processor)
	Kick_init(p.Kick, sr)
	Kick_start(p.Kick)
	p.Snare_Drum = new(Snare_Drum_Processor)
	Snare_Drum_init(p.Snare_Drum, sr)
	Snare_Drum_start(p.Snare_Drum)
	p.sax = new(sax_Processor)
	sax_init(p.sax, sr)
	sax_start(p.sax)
}

project_process :: proc(p: ^Project_State) -> (f32, f32) {
	mixed_left: f32 = 0.0
	mixed_right: f32 = 0.0
	{ l, r := Kick_process(p.Kick); mixed_left += l; mixed_right += r }
	{ l, r := Snare_Drum_process(p.Snare_Drum); mixed_left += l; mixed_right += r }
	{ l, r := sax_process(p.sax); mixed_left += l; mixed_right += r }
	mixed_left = math.tanh(mixed_left * 0.800)
	mixed_right = math.tanh(mixed_right * 0.800)
	return mixed_left, mixed_right
}

project_destroy :: proc(p: ^Project_State) {
	free(p.Kick)
	free(p.Snare_Drum)
	free(p.sax)
}

