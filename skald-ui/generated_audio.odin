	}
	return 0.0, false
}

Kick_process :: proc(p: ^Kick_Processor) -> (f32, f32) {
	sample_rate := p.sample_rate
	output_left: f32 = 0.0
	output_right: f32 = 0.0
	Kick_process_sequence(p)
	p.total_samples += 1

	for v_idx in 0..<8 {
		voice := &p.voices[v_idx]
		if !voice.active do continue

		voice.age += 1.0 / sample_rate;
		if voice.current_freq != voice.target_freq {
			glide_k := 1.0 / math.max(voice.glide_time * sample_rate, 1.0)
			if glide_k > 1.0 do glide_k = 1.0
			voice.current_freq += (voice.target_freq - voice.current_freq) * glide_k
			if abs(voice.target_freq - voice.current_freq) < 0.1 do voice.current_freq = voice.target_freq
		}
		if voice.age >= voice.duration && voice.duration > 0.0 {
			if voice.adsr_3_stage != .Release && voice.adsr_3_stage != .Idle {
				voice.adsr_3_stage = .Release
				voice.time_released = voice.age
			}
			if voice.adsr_2_stage != .Release && voice.adsr_2_stage != .Idle {
				voice.adsr_2_stage = .Release
				voice.time_released = voice.age
			}
		}
		voice_busy := false
		node_3_out: f32 = 0.0
		node_1_out: f32 = 0.0
		node_4_out: f32 = 0.0
		node_2_out: f32 = 0.0
		node_5_out: f32 = 0.0

		// --- ADSR Node 2 ---
		{
			envelope: f32 = 0.0;
			switch voice.adsr_2_stage {
			case .Idle:
				envelope = 0.0;
			case .Attack:
				if (p.n2_attack) > 0 do envelope = voice.age / math.max(f32(p.n2_attack), 0.000001); else do envelope = 1.0;
				voice.adsr_2_release_level = envelope;
				if voice.age >= (p.n2_attack) {
					voice.adsr_2_stage = .Decay;
				}
			case .Decay:
				time_in_decay := voice.age - (p.n2_attack);
				if (p.n2_decay) > 0 do envelope = 1.0 - (time_in_decay / math.max(f32(p.n2_decay), 0.000001)) * (1.0 - (p.n2_sustain)); else do envelope = (p.n2_sustain);
				voice.adsr_2_release_level = envelope;
				if time_in_decay >= (p.n2_decay) {
					voice.adsr_2_stage = .Sustain;
				}
			case .Sustain:
				envelope = (p.n2_sustain);
				voice.adsr_2_release_level = envelope;
				if envelope <= 0.0001 do voice.adsr_2_stage = .Idle;
			case .Release:
				time_in_release := voice.age - voice.time_released;
				if (p.n2_release) > 0 do envelope = voice.adsr_2_release_level * (1.0 - (time_in_release / math.max(f32(p.n2_release), 0.000001))); else do envelope = 0.0;
				if envelope <= 0 {
					envelope = 0;
					voice.adsr_2_stage = .Idle;
				}
			}
			vel_scale_2 := (1.0 - (0.500)) + (0.500) * voice.velocity;
			node_2_out = (1.0) * envelope * (p.n2_depth) * vel_scale_2;
		}

		// --- Oscillator Node 1 (Unison/Detune) ---
		{
			unison_out: f32 = 0.0;
			unison_count := 1;
			for i in 0..<unison_count {
				detune_amount: f32 = 0.0;
				if unison_count > 1 do detune_amount = (f32(i) / (f32(unison_count) - 1.0) - 0.5) * 2.0 * (5.000);
				detuned_freq := ((voice.current_freq) * math.pow(2.0, math.clamp(f32(node_2_out), -10.0, 10.0))) * math.pow(2.0, detune_amount / 1200.0);
				phase_rads := f32(p.phase) * (f32(math.PI) / 180.0);
				voice.osc_1_phase[i] = math.mod(voice.osc_1_phase[i] + (2 * f32(math.PI) * detuned_freq / sample_rate), 2 * f32(math.PI));
				final_phase := math.mod(voice.osc_1_phase[i] + phase_rads, 2 * f32(math.PI));
				unison_out += math.sin(final_phase);
			}
			if unison_count > 0 do node_1_out = (unison_out / f32(unison_count)) * (p.amplitude);
		}

		// --- ADSR Node 3 ---
		{
			envelope: f32 = 0.0;
			switch voice.adsr_3_stage {
			case .Idle:
				envelope = 0.0;
			case .Attack:
				if (p.n3_attack) > 0 do envelope = voice.age / math.max(f32(p.n3_attack), 0.000001); else do envelope = 1.0;
				voice.adsr_3_release_level = envelope;
				if voice.age >= (p.n3_attack) {
					voice.adsr_3_stage = .Decay;
				}
			case .Decay:
				time_in_decay := voice.age - (p.n3_attack);
				if (p.n3_decay) > 0 do envelope = 1.0 - (time_in_decay / math.max(f32(p.n3_decay), 0.000001)) * (1.0 - (p.n3_sustain)); else do envelope = (p.n3_sustain);
				voice.adsr_3_release_level = envelope;
				if time_in_decay >= (p.n3_decay) {
					voice.adsr_3_stage = .Sustain;
				}
			case .Sustain:
				envelope = (p.n3_sustain);
				voice.adsr_3_release_level = envelope;
				if envelope <= 0.0001 do voice.adsr_3_stage = .Idle;
			case .Release:
				time_in_release := voice.age - voice.time_released;
				if (p.n3_release) > 0 do envelope = voice.adsr_3_release_level * (1.0 - (time_in_release / math.max(f32(p.n3_release), 0.000001))); else do envelope = 0.0;
				if envelope <= 0 {
					envelope = 0;
					voice.adsr_3_stage = .Idle;
				}
			}
			vel_scale_3 := (1.0 - (0.500)) + (0.500) * voice.velocity;
			node_3_out = ((node_1_out)) * envelope * (p.n3_depth) * vel_scale_3;
		}

		// --- Distortion Node 4 (classic) ---
		{
			dist_in_4 := ((node_3_out));
			dist_k_4 := math.max(f32(p.drive), 1.0);
			dist_wet_4 := (f32(math.PI) + dist_k_4) * dist_in_4 / (f32(math.PI) + dist_k_4 * abs(dist_in_4));
			tone_k_4 := math.clamp(2.0 * f32(math.PI) * math.clamp(f32(p.tone), 100.0, 20000.0) / sample_rate, 0.001, 1.0);
			voice.dist_4_tone += tone_k_4 * (dist_wet_4 - voice.dist_4_tone);
			mix_4 := math.clamp(f32(p.mix), 0.0, 1.0);
			node_4_out = dist_in_4 * (1.0 - mix_4) + voice.dist_4_tone * mix_4;
		}

		output_left += node_4_out
		output_right += node_4_out
		if voice.adsr_3_stage != .Idle do voice_busy = true
		if voice.adsr_2_stage != .Idle do voice_busy = true
		if !voice_busy do voice.active = false
	}
	return output_left, output_right
}
Kick_process_sequence :: proc(p: ^Kick_Processor) {
	if !p.playing do return
	samples_per_step_f := p.sample_rate * 60.0 / (p.bpm * 4.0)
	if p.samples_until_next_step == 0 {
		switch p.current_step % 32 {
		case 0:
			Kick_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 2:
			Kick_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 5:
			Kick_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 7:
			Kick_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 9:
			Kick_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 11:
			Kick_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 14:
			Kick_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 17:
			Kick_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 18:
			Kick_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 19:
			Kick_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 21:
			Kick_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 22:
			Kick_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 23:
			Kick_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 25:
			Kick_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 27:
			Kick_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 29:
			Kick_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 30:
			Kick_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		case 31:
			Kick_note_on(p, 60, 1.000, f32(1.000) * (60.0 / p.bpm / 4.0))
		}
		p.current_step += 1
		if p.current_step >= 16 {
			if p.loop {
				p.current_step = 0
			} else {
				p.playing = false
			}
		}
		p.step_frac_acc += samples_per_step_f
		n_step := u64(math.max(p.step_frac_acc, 1.0))
		p.step_frac_acc -= f32(n_step)
		p.samples_until_next_step = n_step - 1
	} else {
		p.samples_until_next_step -= 1
	}
}

Snare_Drum_Voice_State :: struct {
	active: bool,
	note: u8,
	velocity: f32,
	age: f32,
	time_released: f32,
	current_freq: f32,
	target_freq: f32,
	glide_time: f32,
	duration: f32,
	osc_3_phase: [1]f32,
	noise_1_rng: PRNG_State,
	filter_4_low: f32,
	filter_4_band: f32,
	adsr_5_stage: ADSR_Stage,
	adsr_5_release_level: f32,
}

Snare_Drum_Processor :: struct {
	sample_rate: f32,
	bpm: f32,
	voices: [8]Snare_Drum_Voice_State,
	prng: PRNG_State,
	total_samples: u64,
	playing: bool,
	loop: bool,
	current_step: u64,
	samples_until_next_step: u64,
	step_frac_acc: f32,
	pulseWidth: f32,
	resonance: f32,
	depth: f32,
	n3_amplitude: f32,
	attack: f32,
	frequency: f32,
	n1_amplitude: f32,
	decay: f32,
	sustain: f32,
	release: f32,
	cutoff: f32,
	phase: f32,
}

Snare_Drum_init :: proc(p: ^Snare_Drum_Processor, sr: f32) {
	p.sample_rate = sr
	p.bpm = 120.000
	p.prng.state = 12345
	p.loop = true
	for i in 0..<8 {
		v := &p.voices[i]
		v.noise_1_rng.state = u32(0xC0FFEE01) ~ u32(i + 1) * 2654435761
	}
	p.pulseWidth = 0.500
	p.resonance = 0.593
	p.depth = 1.000
	p.n3_amplitude = 0.500
	p.attack = 0.001
	p.frequency = 220.000
	p.n1_amplitude = 1.000
	p.decay = 0.159
	p.sustain = 0.000
	p.release = 0.133
	p.cutoff = 2449.232
	p.phase = 0.000
}

Snare_Drum_note_on :: proc(p: ^Snare_Drum_Processor, note: u8, velocity: f32, duration: f32) {
	voice_idx := -1
	for i in 0..<8 {
		if !p.voices[i].active {
			voice_idx = i
			break
		}
	}
	stolen := false
	if voice_idx == -1 {
		stolen = true
		oldest_age: f32 = -1.0
		for i in 0..<8 {
			if p.voices[i].age > oldest_age {
				oldest_age = p.voices[i].age
				voice_idx = i
			}
		}
	}

	v := &p.voices[voice_idx]
	prev_freq := v.current_freq
	v.active = true
	v.note = note
	v.velocity = velocity
	v.age = 0.0
	v.time_released = 0.0
	freq := 440.0 * math.pow(2.0, (f32(note) - 69.0) / 12.0)
	v.target_freq = freq
	v.glide_time = 0.050
	if stolen && v.glide_time > 0.0 && prev_freq > 0.0 {
		v.current_freq = prev_freq
	} else {
		v.current_freq = freq
	}
	v.duration = duration
	v.osc_3_phase = {}
	v.filter_4_low = 0.0
	v.filter_4_band = 0.0
	v.adsr_5_stage = .Attack
	v.adsr_5_release_level = 0.0
}

Snare_Drum_note_off :: proc(p: ^Snare_Drum_Processor, note: u8) {
	best := -1
	best_age: f32 = -1.0
	for i in 0..<8 {
		if p.voices[i].active && p.voices[i].note == note {
			if p.voices[i].adsr_5_stage == .Release do continue
			if p.voices[i].age > best_age {
				best_age = p.voices[i].age
				best = i
			}
		}
	}
	if best >= 0 {
		p.voices[best].time_released = p.voices[best].age
		p.voices[best].adsr_5_stage = .Release
	}
}

Snare_Drum_trigger :: proc(p: ^Snare_Drum_Processor, note: u8 = 60, velocity: f32 = 1.0, duration: f32 = 0.0) {
	Snare_Drum_note_on(p, note, velocity, duration)
}

Snare_Drum_start :: proc(p: ^Snare_Drum_Processor) {
	p.playing = true
	p.current_step = 0
	p.samples_until_next_step = 0
	p.step_frac_acc = 0.0
}

Snare_Drum_stop :: proc(p: ^Snare_Drum_Processor) {
	p.playing = false
}

Snare_Drum_set_loop :: proc(p: ^Snare_Drum_Processor, loop: bool) {
	p.loop = loop
}

Snare_Drum_is_playing :: proc(p: ^Snare_Drum_Processor) -> bool {
	if p.playing do return true
	for i in 0..<8 {
		if p.voices[i].active do return true
	}
	return false
}

Snare_Drum_set_pulseWidth :: proc(p: ^Snare_Drum_Processor, value: f32) {
	v := value
	if v < 0.000 do v = 0.000
	if v > 1.000 do v = 1.000
	p.pulseWidth = v
}

